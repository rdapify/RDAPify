          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(rdap_errors_total[5m])) / clamp_min(sum(rate(rdap_requests_total[5m])), 1)",
          "legendFormat": "error rate",
          "refId": "A"
        }
