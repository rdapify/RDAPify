# Tooling — promtool is fetched on demand by tools/get_promtool.sh,
# never committed (binary is ~189 MB, exceeds GitHub's 100 MB limit
# anyway). Tarballs and extracted prometheus-* directories are also
# transient artefacts of the fetch.
tools/promtool
tools/prometheus-*.tar.gz
tools/prometheus-*/

